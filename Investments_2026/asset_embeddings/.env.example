# Copy this file to .env and replace each placeholder with an exact object URI.
# .env is ignored; never commit real cloud resource identifiers.

ASSET_EMBEDDINGS_13F_SAMPLE_URI=gs://<private-bucket>/<private-13f-sample-object>
ASSET_EMBEDDINGS_NPORT_SAMPLE_URI=gs://<private-bucket>/<private-nport-sample-object>
ASSET_EMBEDDINGS_13F_DICTIONARY_URI=gs://<private-bucket>/<private-13f-dictionary-object>
ASSET_EMBEDDINGS_NPORT_DICTIONARY_URI=gs://<private-bucket>/<private-nport-dictionary-object>

# Complete private products. The sync script reads these manifests and downloads
# only their explicitly enumerated objects; bucket-listing permission is not required.
ASSET_EMBEDDINGS_13F_MANIFEST_URI=gs://<private-bucket>/<private-13f-manifest-object>
ASSET_EMBEDDINGS_NPORT_MANIFEST_URI=gs://<private-bucket>/<private-nport-manifest-object>
